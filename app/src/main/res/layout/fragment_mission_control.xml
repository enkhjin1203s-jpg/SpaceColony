<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0E1A"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MISSION CONTROL"
        android:textColor="#7DD3FC"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txtThreatStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No active threat."
        android:textColor="#F87171"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:background="#1A0A0A"
        android:padding="10dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txtEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No crew in Mission Control. Move crew from Quarters."
        android:textColor="#475569"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMission"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3" />

    <ScrollView
        android:id="@+id/scrollMissionLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:layout_marginTop="8dp"
        android:background="#0F172A">

        <TextView
            android:id="@+id/txtMissionLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:padding="8dp" />
    </ScrollView>

    <Button
        android:id="@+id/btnLaunchMission"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="LAUNCH MISSION"
        android:backgroundTint="#7C3AED"
        android:textColor="#FFFFFF"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button android:id="@+id/btnAttack"  android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="ATTACK"  android:backgroundTint="#991B1B" android:textColor="#FFF" android:layout_marginEnd="4dp" android:enabled="false" />
        <Button android:id="@+id/btnDefend"  android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="DEFEND"  android:backgroundTint="#1D4ED8" android:textColor="#FFF" android:layout_marginEnd="4dp" android:enabled="false" />
        <Button android:id="@+id/btnSpecial" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="SPECIAL" android:backgroundTint="#92400E" android:textColor="#FFF" android:enabled="false" />

    </LinearLayout>

    <Button
        android:id="@+id/btnEndMission"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="ABORT MISSION"
        android:backgroundTint="#1E293B"
        android:textColor="#64748B"
        android:layout_marginTop="6dp"
        android:visibility="gone" />

</LinearLayout>