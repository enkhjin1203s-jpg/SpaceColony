<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="#111827"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/checkBoxCrew"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#7DD3FC"
            android:layout_marginEnd="10dp" />

        <ImageView
            android:id="@+id/imgCrew"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="12dp"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtCrewName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E0F2FE"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtCrewInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/txtCrewEnergy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#4ADE80"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>