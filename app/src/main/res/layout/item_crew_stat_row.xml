<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111827"
    android:padding="14dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <TextView
            android:id="@+id/txtCrewStatName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#F1F5F9"
            android:textSize="14sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/txtCrewWinRate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#4ADE80"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:background="#1E293B"
        android:layout_marginBottom="10dp">
        <View
            android:id="@+id/viewCrewWinBar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="#4ADE80" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MISSIONS" android:textColor="#475569" android:textSize="9sp" android:textStyle="bold"/>
            <TextView android:id="@+id/txtCrewStatMissions" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#7DD3FC" android:textSize="18sp" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WINS" android:textColor="#475569" android:textSize="9sp" android:textStyle="bold"/>
            <TextView android:id="@+id/txtCrewStatWins" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#4ADE80" android:textSize="18sp" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LOSSES" android:textColor="#475569" android:textSize="9sp" android:textStyle="bold"/>
            <TextView android:id="@+id/txtCrewStatLosses" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#F87171" android:textSize="18sp" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TRAINING" android:textColor="#475569" android:textSize="9sp" android:textStyle="bold"/>
            <TextView android:id="@+id/txtCrewStatTraining" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FCD34D" android:textSize="18sp" android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>