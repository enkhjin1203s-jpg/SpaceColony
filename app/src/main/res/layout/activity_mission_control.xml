<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mission Control"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crew currently in Quarters:"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtQuartersList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/edtCrewId1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter first crew ID"
            android:inputType="number"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edtCrewId2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter second crew ID"
            android:inputType="number"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnMoveToMissionControl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Move Selected Crew to Mission Control"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnLaunchMission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Launch Mission"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/txtMissionCrewList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/txtMissionLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:scrollbars="vertical" />
        <Button
            android:id="@+id/btnBackHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back to Home"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnGoQuarters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Go to Quarters"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnGoSimulator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Go to Simulator"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>